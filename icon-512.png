<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 192 192">
  <rect width="192" height="192" rx="40" fill="#060C18"/>
  <rect x="20" y="20" width="152" height="152" rx="30" fill="#0D1626"/>
  <!-- Wave -->
  <path d="M30 110 Q50 90 70 110 Q90 130 110 110 Q130 90 150 110 Q162 122 170 115" 
        stroke="#0EA5E9" stroke-width="5" fill="none" stroke-linecap="round"/>
  <!-- H letter -->
  <text x="96" y="88" font-family="Arial Black,sans-serif" font-size="52" font-weight="900" 
        fill="#0EA5E9" text-anchor="middle" dominant-baseline="middle">H</text>
  <!-- Hotel Cala text -->
  <text x="96" y="145" font-family="Arial,sans-serif" font-size="14" font-weight="700"
        fill="#64748B" text-anchor="middle" letter-spacing="2">CALA</text>
</svg>